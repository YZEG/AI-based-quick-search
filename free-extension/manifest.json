{
  "manifest_version": 3,
  "name": "Hover Dictionary",
  "version": "1.0.0",
  "description": "Show word definition near selected text with AI support",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "https://api.xiaomimimo.com/*",
    "https://api.dictionaryapi.dev/*",
    "https://*.wikipedia.org/*"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "show-popup": {
      "suggested_key": {
        "default": "Ctrl+Shift+D"
      },
      "description": "Show definition popup for selected text"
    }
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
